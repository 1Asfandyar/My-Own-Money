# Git history — never needed in images
/.git/
/.gitignore
/.gitattributes

# Bundler config
/.bundle

# Environment files (secrets must never land in an image)
/.env*
!/.env*.erb

# Master key and credentials — injected at runtime via RAILS_MASTER_KEY env var
/config/master.key
/config/credentials/*.key

# Logs and tmp
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/.keep

# Storage (uploaded files — use object storage in production)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Test/spec files — not needed at runtime
/spec/
/test/

# CI/CD config — not needed in the image
/.github/
/.rubocop*

# Documentation
/README.md
/CHANGELOG.md

# Node modules if ever added
/node_modules/
