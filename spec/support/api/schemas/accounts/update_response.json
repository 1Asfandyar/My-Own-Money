{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "account"],
  "properties": {
    "success": { "type": "boolean", "enum": [true] },
    "account": { "$ref": "#/definitions/account" }
  },
  "definitions": {
    "account": {
      "type": "object",
      "required": ["id", "name", "current_balance_cents", "initial_balance_cents", "is_archived", "user_id", "created_at", "updated_at"],
      "properties": {
        "id":                    { "type": "integer" },
        "name":                  { "type": "string" },
        "current_balance_cents": { "type": "integer" },
        "initial_balance_cents": { "type": "integer" },
        "is_archived":           { "type": "boolean" },
        "currency_id":           { "type": ["integer", "null"] },
        "user_id":               { "type": "integer" },
        "created_at":            { "type": "string" },
        "updated_at":            { "type": "string" }
      }
    }
  }
}
