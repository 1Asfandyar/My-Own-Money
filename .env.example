# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# ── Database ──────────────────────────────────────────────────────────────────
HOPIN_DATABASE_PASSWORD=rupeerally

# ── CORS (comma-separated, no trailing slash) ─────────────────────────────────
# Production example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=localhost:3000,localhost:3001,localhost:8081

# OAuth credentials for Google login (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Rails ─────────────────────────────────────────────────────────────────────
# RAILS_MASTER_KEY is only needed if you deploy without config/master.key.
# For local development, config/master.key handles this automatically.
# RAILS_MASTER_KEY=

# Optional log level override (debug, info, warn, error, fatal)
# RAILS_LOG_LEVEL=info

# ── Puma ──────────────────────────────────────────────────────────────────────
# PORT=3000
# RAILS_MAX_THREADS=3
# WEB_CONCURRENCY=2
